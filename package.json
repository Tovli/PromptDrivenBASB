{
  "name": "prompt-driven-basb",
  "version": "0.1.1",
  "description": "Prompt-driven Building a Second Brain workspace packaged for npm.",
  "keywords": [
    "basb",
    "second-brain",
    "prompts",
    "markdown",
    "knowledge-management"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tovli/PromptDrivenBASB.git"
  },
  "homepage": "https://github.com/Tovli/PromptDrivenBASB#readme",
  "bugs": {
    "url": "https://github.com/Tovli/PromptDrivenBASB/issues"
  },
  "license": "MIT",
  "type": "commonjs",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "default": "./index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "AGENTS.md",
    "BASBGuide.md",
    "LICENSE",
    "README.md",
    "bootstrap",
    "docs",
    "examples",
    "scripts/postinstall.cjs",
    "scripts/lib/scaffold-workspace.cjs",
    "templates",
    "vault",
    "index.js",
    "index.d.ts"
  ],
  "scripts": {
    "test": "node --test tests/package.test.js tests/scaffold-workspace.test.js tests/publish-version.test.js",
    "pack:check": "npm pack --dry-run",
    "postinstall": "node scripts/postinstall.cjs",
    "prepare:publish-version": "node scripts/prepare-publish-version.cjs"
  },
  "engines": {
    "node": ">=22"
  }
}
